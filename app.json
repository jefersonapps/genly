{
  "expo": {
    "name": "Genly",
    "slug": "Genly",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.png",
    "scheme": "genly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/adaptive-icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.genly.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Permitir acesso biométrico para proteger seus dados e backups.",
        "NSPhotoLibraryUsageDescription": "Permitir acesso para salvar e carregar imagens.",
        "NSPhotoLibraryAddUsageDescription": "Permitir salvar imagens na galeria.",
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "PDF Document",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "com.adobe.pdf"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.genly.app",
      "versionCode": 6,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "genly",
            "host": "*",
            "pathPattern": ".*"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "mimeType": "application/pdf"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/adaptive-icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#0A0A0A",
            "image": "./assets/adaptive-icon.png"
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir acesso biométrico para proteger seus dados e backups."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para anexar às notas."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "O app precisa salvar imagens na sua galeria.",
          "savePhotosPermission": "O app precisa salvar imagens na sua galeria.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-share-intent",
        {
          "ios": {
            "activationRules": {
              "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
              "NSExtensionActivationSupportsImageWithMaxCount": 10,
              "NSExtensionActivationSupportsText": true
            }
          }
        }
      ],
      "expo-sharing",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.20",
            "packagingOptions": {
              "pickFirst": [
                "**/libjsc.so",
                "**/libc++_shared.so"
              ]
            }
          }
        }
      ],
      "./plugins/withMaterialPickerStyles.js",
      "./plugins/withShareTargets.js",
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-web-browser",
      ["react-native-android-widget", {
        "fonts": [
          "./assets/fonts/Montserrat-Regular.ttf",
          "./assets/fonts/Montserrat-Bold.ttf",
          "./assets/fonts/Montserrat-Medium.ttf",
          "./assets/fonts/Montserrat-SemiBold.ttf"
        ],
        "widgets": [
          {
            "name": "Reminders",
            "label": "Genly - Lembretes",
            "minWidth": "110dp",
            "minHeight": "40dp",
            "minResizeWidth": "72dp",
            "minResizeHeight": "40dp",
            "targetCellWidth": 4,
            "targetCellHeight": 2,
            "description": "Notas com lembretes agendados",
            "previewImage": "./assets/widget-preview/reminders.png",
            "updatePeriodMillis": 1800000,
            "resizeMode": "horizontal|vertical"
          },
          {
            "name": "RecentTasks",
            "label": "Genly - Notas Recentes",
            "minWidth": "110dp",
            "minHeight": "40dp",
            "minResizeWidth": "72dp",
            "minResizeHeight": "40dp",
            "targetCellWidth": 4,
            "targetCellHeight": 2,
            "description": "As 10 notas mais recentes",
            "previewImage": "./assets/widget-preview/recent-tasks.png",
            "updatePeriodMillis": 1800000,
            "resizeMode": "horizontal|vertical"
          },
          {
            "name": "RecentMindMaps",
            "label": "Genly - Mapas Mentais",
            "minWidth": "110dp",
            "minHeight": "40dp",
            "minResizeWidth": "72dp",
            "minResizeHeight": "40dp",
            "targetCellWidth": 4,
            "targetCellHeight": 2,
            "description": "Os 10 mapas mentais mais recentes",
            "previewImage": "./assets/widget-preview/mind-maps.png",
            "updatePeriodMillis": 1800000,
            "resizeMode": "horizontal|vertical"
          },
          {
            "name": "RecentFlashcards",
            "label": "Genly - Flashcards",
            "minWidth": "110dp",
            "minHeight": "40dp",
            "minResizeWidth": "72dp",
            "minResizeHeight": "40dp",
            "targetCellWidth": 4,
            "targetCellHeight": 2,
            "description": "Os 10 flashcards mais recentes",
            "previewImage": "./assets/widget-preview/flashcards.png",
            "updatePeriodMillis": 1800000,
            "resizeMode": "horizontal|vertical"
          },
          {
            "name": "GroupWidget",
            "label": "Genly - Grupo",
            "minWidth": "110dp",
            "minHeight": "40dp",
            "minResizeWidth": "72dp",
            "minResizeHeight": "40dp",
            "targetCellWidth": 4,
            "targetCellHeight": 2,
            "description": "Notas recentes de um grupo",
            "previewImage": "./assets/widget-preview/group.png",
            "updatePeriodMillis": 1800000,
            "resizeMode": "horizontal|vertical",
            "widgetFeatures": "reconfigurable"
          }
        ]
      }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f85322f-3135-492c-8ca8-28b506c2d1a9"
      }
    }
  }
}
